# Copy this file to .env and fill in values.
# Local development:
DEBUG=True
SECRET_KEY=replace-with-a-long-random-string

# Production: set DEBUG=False and a real SECRET_KEY.
DATABASE_URL=postgres://postgres:password@localhost:5432/campo_db
ALLOWED_HOSTS=yourdomain.com

# M-Pesa (Safaricom Daraja portal)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/billing/mpesa/callback/
MPESA_ENV=sandbox

# Africa's Talking (SMS)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=CampoPawa

# Email (leave blank to use console backend in dev)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@campopawa.com
